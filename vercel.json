{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.)",
      "dest": "backend/server.js"
    },
    {
      "src": "/js/(.)",
      "dest": "/js/$1"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/(..html)",
      "dest": "/$1"
    },
    {
      "src": "/(.)",
      "dest": "backend/server.js"
    }
  ]
}